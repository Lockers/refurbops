APP_NAME=RefurbOps API
APP_ENV=local
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_PUBLIC_URL=https://app.refurbops.local
API_PUBLIC_URL=https://api.refurbops.local
FRONTEND_ORIGIN=https://app.refurbops.local

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=refurbops
REDIS_URL=redis://localhost:6379/0

ACCESS_COOKIE_NAME=refurbops_access
REFRESH_COOKIE_NAME=refurbops_refresh
ACCESS_TOKEN_TTL_MINUTES=10
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_ABSOLUTE_TIMEOUT_HOURS=12
JWT_ACTIVE_KID=local-dev-key-1
JWT_ISSUER=refurbops-api
JWT_AUDIENCE=refurbops-web
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=

PLATFORM_OWNER_EMAIL=info@repairedtech.co.uk
PLATFORM_OWNER_INITIAL_PASSWORD=
PLATFORM_OWNER_REQUIRE_MFA=true
MFA_ISSUER=RefurbOps

EMAIL_PROVIDER=postmark
EMAIL_FROM_NAME=RefurbOps
EMAIL_FROM_ADDRESS=noreply@repairedtech.co.uk
EMAIL_REPLY_TO=info@repairedtech.co.uk
POSTMARK_SERVER_TOKEN=
POSTMARK_WEBHOOK_SECRET=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
MAILPIT_UI_URL=http://localhost:8025

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_USE_TAX=true
STRIPE_PRICE_LOOKUP_DEFAULT_CURRENCY=GBP

AWS_REGION=eu-west-2
AWS_SECRETS_MANAGER_PREFIX=refurbops/local
AWS_KMS_KEY_ID=
AWS_S3_BUCKET=
AWS_SQS_QUEUE_URL=

OTEL_ENABLED=false
OTEL_SERVICE_NAME=refurbops-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
